doctype html
head
  meta(charset='UTF-8')
  meta(name='viewport' content='width=device-width, initial-scale=1.0')
  title Sales Dashboard
  link(href='https://cdn.jsdelivr.net/npm/bootstrap@5.3.8/dist/css/bootstrap.min.css' rel='stylesheet')
  link(href='https://cdn.jsdelivr.net/npm/bootstrap-icons@1.13.1/font/bootstrap-icons.css' rel='stylesheet')
  link(rel='stylesheet' href='style.css')
  style.
// SIDEBAR
aside.sidebar
  .sidebar-header
    .row
      img.col-3(src='/public/images/logo.png' alt='NyondoStock Logo' width='60px' height='40px')
      h4.fw-bold.mb-1.col-9 NyondoStock
    p.mb-0.text-secondary.topuser Sales Attendant
  .sidebar-menu
    a.sidebar-link.active(href='salesdashboard.html')
      i.bi.bi-grid
      |  Dashboard
    a.sidebar-link.active(href='recordsale.html')
      i.bi.bi-cart
      |  Record Sale
    a.sidebar-link(href='stockcheck.html')
      i.bi.bi-box-seam
      |  Stock Check
    a.sidebar-link(href='receipts.html')
      i.bi.bi-receipt
      |  Receipts
  .sidebar-footer
    a.sidebar-link.mb-0(href='login.html')
      i.bi.bi-box-arrow-right
      |  Logout
// MAIN
main.main
  // TOPBAR
  .topbar
    h3.fw-bold.mb-0 Dashboard
    .d-flex.align-items-center.gap-3
      button.btn.border.rounded-4.position-relative.p-3
        i.bi.bi-bell.fs-4
        span.position-absolute.top-0.end-0.translate-middle.p-1.bg-danger.border.border-light.rounded-circle
      button.btn.bg-light.rounded-4.px-4.py-3.fw-bold
        i.bi.bi-person.me-2
        |  Sales User
  // SCROLLABLE CONTENT
  .content
    // SALES DASHBOARD CONTENT
    // Summary Cards
    .row.g-4.mb-4
      .col-md-6.col-xl-3
        .card.border-0.shadow-sm.h-100
          .card-body.p-4
            .purple-bg.text-white.rounded-4.d-flex.align-items-center.justify-content-center.dashboard-icon.mb-4
              i.bi.bi-cart.fs-3
            p.text-secondary.mb-2 Today&apos;s Sales
            h2.fw-bold.mb-0 12
      .col-md-6.col-xl-3
        .card.border-0.shadow-sm.h-100
          .card-body.p-4
            .purple-bg.text-white.rounded-4.d-flex.align-items-center.justify-content-center.dashboard-icon.mb-4
              i.bi.bi-currency-dollar.fs-3
            p.text-secondary.mb-2 Revenue
            h2.fw-bold.mb-0 45,600,000 UGX
      .col-md-6.col-xl-3
        .card.border-0.shadow-sm.h-100
          .card-body.p-4
            .purple-bg.text-white.rounded-4.d-flex.align-items-center.justify-content-center.dashboard-icon.mb-4
              i.bi.bi-graph-up-arrow.fs-3
            p.text-secondary.mb-2 Transactions
            h2.fw-bold.mb-0 28
      .col-md-6.col-xl-3
        .card.border-0.shadow-sm.h-100
          .card-body.p-4
            .purple-bg.text-white.rounded-4.d-flex.align-items-center.justify-content-center.dashboard-icon.mb-4
              i.bi.bi-box-seam.fs-3
            p.text-secondary.mb-2 Items Sold
            h2.fw-bold.mb-0 342
    // Recent Sales
    .card.border-0.shadow-sm
      .card-body.p-0
        .p-4.border-bottom
          h4.fw-bold.mb-0 Recent Sales
        .table-responsive
          table.table.align-middle.mb-0
            thead.table-light
              tr
                th.px-4.py-3.text-uppercase Receipt ID
                th.px-4.py-3.text-uppercase Customer
                th.px-4.py-3.text-uppercase Product
                th.px-4.py-3.text-uppercase Quantity
                th.px-4.py-3.text-uppercase Amount
                th.px-4.py-3.text-uppercase Time
            tbody
              tr
                td.px-4.py-4.fw-semibold RC001
                td.px-4.py-4.text-secondary John Doe
                td.px-4.py-4.text-secondary Cement - 50kg
                td.px-4.py-4.text-secondary 100
                td.px-4.py-4.fw-semibold 3,500,000 UGX
                td.px-4.py-4.text-secondary 10:30 AM
              tr
                td.px-4.py-4.fw-semibold RC002
                td.px-4.py-4.text-secondary Jane Smith
                td.px-4.py-4.text-secondary Iron Bars - 12mm
                td.px-4.py-4.text-secondary 50
                td.px-4.py-4.fw-semibold 2,800,000 UGX
                td.px-4.py-4.text-secondary 11:15 AM
              tr
                td.px-4.py-4.fw-semibold RC003
                td.px-4.py-4.text-secondary Mike Johnson
                td.px-4.py-4.text-secondary Iron Sheets
                td.px-4.py-4.text-secondary 75
                td.px-4.py-4.fw-semibold 4,200,000 UGX
                td.px-4.py-4.text-secondary 12:00 PM
              tr
                td.px-4.py-4.fw-semibold RC004
                td.px-4.py-4.text-secondary Sarah Wilson
                td.px-4.py-4.text-secondary Nails - 3 inch
                td.px-4.py-4.text-secondary 20
                td.px-4.py-4.fw-semibold 450,000 UGX
                td.px-4.py-4.text-secondary 1:45 PM
              tr
                td.px-4.py-4.fw-semibold RC005
                td.px-4.py-4.text-secondary David Brown
                td.px-4.py-4.text-secondary Cement - 50kg
                td.px-4.py-4.text-secondary 200
                td.px-4.py-4.fw-semibold 7,000,000 UGX
                td.px-4.py-4.text-secondary 2:30 PM
