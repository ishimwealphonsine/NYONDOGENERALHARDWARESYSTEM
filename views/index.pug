<!DOCTYPE html>
<html lang="en">
<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <title>Nyondo General Hardware</title>
    <!-- Bootstrap CDN -->
    <link href="https://jsdelivr.net" rel="stylesheet">
    <link rel="stylesheet" href="https://jsdelivr.net">
    <link rel="stylesheet" href="style.css">
</head>
<body class="bg-light">

    <!-- Navbar -->
    <nav class="navbar bg-white py-3">
        <div class="container">
            <a class="navbar-brand fw-bold d-flex align-items-center gap-2" href="#">
                <i class="bi bi-box-seam text-purple fs-4"></i> NYONDO General Hardware LTD
            </a>
            <button class="btn bg-purple text-white px-4 fw-bold">Login</button>
        </div>
    </nav>

    <!-- Main Content -->
    <div class="container py-5">
        <div class="row align-items-center">
            
            <!-- Left Side -->
            <div class="col-lg-6">
                <h1 class="display-3 fw-bold mb-3">Hardware Management System</h1>
                <p class="text-secondary mb-4 fs-5">Efficient stock, sales, and financial management for modern hardware businesses</p>
                <button class="btn bg-purple text-white btn-lg px-4 py-2 mb-5">Login to System</button>

                <!-- Bottom Cards -->
                <div class="d-flex gap-3 mt-4">
                    <div class="bg-white p-3 rounded-4 shadow-sm border flex-fill">
                        <i class="bi bi-box text-purple fs-3"></i>
                        <div class="small fw-bold mt-2">Stock Management</div>
                    </div>
                    <div class="bg-white p-3 rounded-4 shadow-sm border flex-fill">
                        <i class="bi bi-graph-up text-purple fs-3"></i>
                        <div class="small fw-bold mt-2">Sales Tracking</div>
                    </div>
                    <div class="bg-white p-3 rounded-4 shadow-sm border flex-fill">
                        <i class="bi bi-boxes text-purple fs-3"></i>
                        <div class="small fw-bold mt-2">Inventory Control</div>
                    </div>
                </div>
            </div>

            <!-- Right Side Preview -->
            <div class="col-lg-5 offset-lg-1 d-none d-lg-block">
                <div class="bg-white p-4 rounded-5 shadow-lg border">
                    <!-- List Item 1 -->
                    <div class="d-flex align-items-center p-3 mb-3 bg-light rounded-4">
                        <div class="bg-purple text-white p-2 rounded-3 me-3"><i class="bi bi-box"></i></div>
                        <div><div class="fw-bold">Cement</div><small class="text-muted">Building Materials</small></div>
                    </div>
                    <!-- List Item 2 -->
                    <div class="d-flex align-items-center p-3 mb-3 bg-light rounded-4">
                        <div class="bg-purple text-white p-2 rounded-3 me-3"><i class="bi bi-stack"></i></div>
                        <div><div class="fw-bold">Iron Bars</div><small class="text-muted">Construction Steel</small></div>
                    </div>
                    <!-- List Item 3 -->
                    <div class="d-flex align-items-center p-3 bg-light rounded-4">
                        <div class="bg-purple text-white p-2 rounded-3 me-3"><i class="bi bi-activity"></i></div>
                        <div><div class="fw-bold">Iron Sheets</div><small class="text-muted">Roofing Materials</small></div>
                    </div>
                </div>
            </div>

        </div>
    </div>

</body>
</html>