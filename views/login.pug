doctype html
head
  meta(charset='UTF-8')
  meta(name='viewport' content='width=device-width, initial-scale=1.0')
  title NyondoStock Login
  link(href='https://cdn.jsdelivr.net/npm/bootstrap@5.3.8/dist/css/bootstrap.min.css' rel='stylesheet')
  link(href='https://cdn.jsdelivr.net/npm/bootstrap-icons@1.13.1/font/bootstrap-icons.css' rel='stylesheet')
  link(rel='stylesheet' href='/css/style.css')
.container.vh-100.d-flex.flex-column.justify-content-center.align-items-center
  .card.login-card.border-0.shadow-lg.w-100
    .card-body.p-4
      .container.row
        img.col-2(src='/images/logo.png' alt='NyondoStock Logo' width='40' height='40')
        h2.fw-bold.mb-3.col-9 Login to Your Account
      p.fw-semibold.mb-2 Select Role
      .row.g-2.mb-2
        .col-3
          .role-card.active.text-center.p-3(data-role='Sales Attendant')
            i.bi.bi-person.fs-4.d-block.mb-1
            span Sales
        .col-3
          .role-card.text-center.p-3(data-role='Store Manager')
            i.bi.bi-shop.fs-4.d-block.mb-1
            span Store
        .col-3
          .role-card.text-center.p-3(data-role='Accounts/Admin')
            i.bi.bi-briefcase.fs-4.d-block.mb-1
            span Accounts/Admin
      p#selectedRoleText.fs-5.text-secondary.mb-3 Sales Attendant
      form(action='/auth/login' method='POST')
        .mb-3
          label.form-label.fw-semibold Email 
          input.form-control(type='text' name='email' placeholder='Enter your email' required='')
        .mb-3
          label.form-label.fw-semibold Password
          input.form-control(type='password' name='password' placeholder='Enter your password' required='')
        input#selectedRoleInput(type='hidden' name='role' value='Sales Attendant')
        button.btn.btn-purple.btn-lg.w-100.fw-bold.py-3(type='submit' href='admindashboard.html')
          | Login
  a.text-decoration-none.mt-3.backtohome(href='index.html')
    | Back to Home
script.
  const roleCards = document.querySelectorAll(".role-card");
  const selectedRoleText = document.getElementById("selectedRoleText");
  const selectedRoleInput = document.getElementById("selectedRoleInput");
  roleCards.forEach(function (card) {
  card.addEventListener("click", function () {
  roleCards.forEach(function (item) {
  item.classList.remove("active");
  });
  card.classList.add("active");
  const role = card.getAttribute("data-role");
  selectedRoleText.textContent = role;
  selectedRoleInput.value = role;
  });
  });
