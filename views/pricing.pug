                input.form-control.form-control-lg(type='number' name='sellingPrice[]' value='56000' required='')
              .col-lg-3
                label.form-label.fw-semibold.text-secondary Profit Margin
                .d-flex.align-items-center.gap-3
                  .progress.rounded-pill.flex-grow-1
                    .progress-bar.purple-bg.rounded-pill(style='width: 16.7%;')
                  strong.purple-text 16.7%
              .col-lg-3.text-lg-end
                p.text-secondary.mb-1 Profit per Unit
                h4.fw-bold.mb-0 8,000 UGX
          // Item 3
          .border.rounded-4.p-4.mb-3
            .row.g-3.align-items-center
              .col-lg-3
                h5.fw-bold.mb-1 Iron Bars - 16mm
                p.text-secondary.mb-0 Cost: 65,000 UGX
                input(type='hidden' name='productName[]' value='Iron Bars - 16mm')
                input(type='hidden' name='unitCost[]' value='65000')
              .col-lg-3
                label.form-label.fw-semibold.text-secondary Selling Price (UGX)
                input.form-control.form-control-lg(type='number' name='sellingPrice[]' value='78000' required='')
              .col-lg-3
                label.form-label.fw-semibold.text-secondary Profit Margin
                .d-flex.align-items-center.gap-3
                  .progress.rounded-pill.flex-grow-1
                    .progress-bar.purple-bg.rounded-pill(style='width: 20%;')
                  strong.purple-text 20.0%
              .col-lg-3.text-lg-end
                p.text-secondary.mb-1 Profit per Unit
                h4.fw-bold.mb-0 13,000 UGX
          // Item 4
          .border.rounded-4.p-4.mb-3
            .row.g-3.align-items-center
              .col-lg-3
                h5.fw-bold.mb-1 Iron Sheets
                p.text-secondary.mb-0 Cost: 48,000 UGX
                input(type='hidden' name='productName[]' value='Iron Sheets')
                input(type='hidden' name='unitCost[]' value='48000')
              .col-lg-3
                label.form-label.fw-semibold.text-secondary Selling Price (UGX)
                input.form-control.form-control-lg(type='number' name='sellingPrice[]' value='56000' required='')
              .col-lg-3
                label.form-label.fw-semibold.text-secondary Profit Margin
                .d-flex.align-items-center.gap-3
                  .progress.rounded-pill.flex-grow-1
                    .progress-bar.purple-bg.rounded-pill(style='width: 16.7%;')
                  strong.purple-text 16.7%
              .col-lg-3.text-lg-end
                p.text-secondary.mb-1 Profit per Unit
                h4.fw-bold.mb-0 8,000 UGX
          // Item 5
          .border.rounded-4.p-4.mb-3
            .row.g-3.align-items-center
              .col-lg-3
                h5.fw-bold.mb-1 Nails - 3 inch
                p.text-secondary.mb-0 Cost: 18,000 UGX
                input(type='hidden' name='productName[]' value='Nails - 3 inch')
                input(type='hidden' name='unitCost[]' value='18000')
              .col-lg-3
                label.form-label.fw-semibold.text-secondary Selling Price (UGX)
                input.form-control.form-control-lg(type='number' name='sellingPrice[]' value='22500' required='')
              .col-lg-3
                label.form-label.fw-semibold.text-secondary Profit Margin
                .d-flex.align-items-center.gap-3
                  .progress.rounded-pill.flex-grow-1
                    .progress-bar.purple-bg.rounded-pill(style='width: 25%;')
                  strong.purple-text 25.0%
              .col-lg-3.text-lg-end
                p.text-secondary.mb-1 Profit per Unit
                h4.fw-bold.mb-0 4,500 UGX
          // Item 6
          .border.rounded-4.p-4
            .row.g-3.align-items-center
              .col-lg-3
                h5.fw-bold.mb-1 Paint - 20L
                p.text-secondary.mb-0 Cost: 95,000 UGX
                input(type='hidden' name='productName[]' value='Paint - 20L')
                input(type='hidden' name='unitCost[]' value='95000')
              .col-lg-3
                label.form-label.fw-semibold.text-secondary Selling Price (UGX)
                input.form-control.form-control-lg(type='number' name='sellingPrice[]' value='125000' required='')
              .col-lg-3
                label.form-label.fw-semibold.text-secondary Profit Margin
                .d-flex.align-items-center.gap-3
                  .progress.rounded-pill.flex-grow-1
                    .progress-bar.purple-bg.rounded-pill(style='width: 31.6%;')
                  strong.purple-text 31.6%
              .col-lg-3.text-lg-end
                p.text-secondary.mb-1 Profit per Unit
                h4.fw-bold.mb-0 30,000 UGX
