doctype html
head
  meta(charset='UTF-8')
  meta(name='viewport' content='width=device-width, initial-scale=1.0')
  title Accounts/Admin Dashboard
  link(href='https://cdn.jsdelivr.net/npm/bootstrap@5.3.8/dist/css/bootstrap.min.css' rel='stylesheet')
  link(href='https://cdn.jsdelivr.net/npm/bootstrap-icons@1.13.1/font/bootstrap-icons.css' rel='stylesheet')
  link(rel='stylesheet' href='style.css')
  style.
// SIDEBAR
aside.sidebar
  .sidebar-header
    .row
      img.col-3(src='/public/images/logo.png' alt='NyondoStock Logo' width='60px' height='40px')
      h4.fw-bold.mb-1.col-9 NyondoStock
    p.mb-0.text-secondary.topuser Store Manager
  .sidebar-menu
    a.sidebar-link.active(href='storedashboard.html')
      i.bi.bi-grid
      |  Dashboard
    a.sidebar-link(href='addstock.html')
      i.bi.bi-box-seam-fill
      |  Add Stock
    a.sidebar-link(href='inventory.html')
      i.bi.bi-box
      |  Inventory
    a.sidebar-link(href='pricing.html')
      i.bi.bi-currency-dollar
      |  Pricing
  .sidebar-footer
    a.sidebar-link.mb-0(href='login.html')
      i.bi.bi-box-arrow-right
      |  Logout
// MAIN
main.main
  // TOPBAR
  .topbar
    h3.fw-bold.mb-0 Pricing
    .d-flex.align-items-center.gap-3
      button.btn.border.rounded-4.position-relative.p-3
        i.bi.bi-bell.fs-4
        span.position-absolute.top-0.end-0.translate-middle.p-1.bg-danger.border.border-light.rounded-circle
      button.btn.bg-light.rounded-4.px-4.py-3.fw-bold
        i.bi.bi-person.me-2
        |  Stock Manager
  // SCROLLABLE CONTENT
  .content
    // PRICING CONTENT
    // Summary Cards
    .row.g-4.mb-4
      .col-md-4
        .card.border-0.shadow-sm.h-100
          .card-body.p-4
            .d-flex.align-items-center.gap-3.mb-4
              .purple-bg.text-white.rounded-4.d-flex.align-items-center.justify-content-center.pricing-icon
                i.bi.bi-currency-dollar.fs-3
              h4.fw-bold.mb-0 Average Margin
            h2.fw-bold.mb-0 21.1%
      .col-md-4
        .card.border-0.shadow-sm.h-100
          .card-body.p-4
            .d-flex.align-items-center.gap-3.mb-4
              .purple-bg.text-white.rounded-4.d-flex.align-items-center.justify-content-center.pricing-icon
                i.bi.bi-graph-up-arrow.fs-3
              h4.fw-bold.mb-0 Highest Margin
            h2.fw-bold.mb-2 31.6%
            p.text-secondary.mb-0 Paint - 20L
      .col-md-4
        .card.border-0.shadow-sm.h-100
          .card-body.p-4
            .d-flex.align-items-center.gap-3.mb-4
              .purple-bg.text-white.rounded-4.d-flex.align-items-center.justify-content-center.pricing-icon
                i.bi.bi-currency-dollar.fs-3
              h4.fw-bold.mb-0 Products
            h2.fw-bold.mb-0 6
    // Edit Product Pricing
    .card.border-0.shadow-sm.mb-4
      .card-body.p-0
        .d-flex.flex-wrap.justify-content-between.align-items-center.gap-3.p-4.border-bottom
          div
            h3.fw-bold.mb-1 Edit Product Pricing
            p.text-secondary.mb-0 Update selling prices and profit margins
          button.btn.purple-bg.purpleBtns.text-white.btn-lg.fw-bold.px-4(type='submit' form='pricingForm')
            i.bi.bi-floppy.me-2
            | Save Changes
        form#pricingForm.p-4(action='update-pricing.html' method='POST')
          // Item 1
          .border.rounded-4.p-4.mb-3
            .row.g-3.align-items-center
              .col-lg-3
                h5.fw-bold.mb-1 Cement - 50kg
                p.text-secondary.mb-0 Cost: 30,000 UGX
                input(type='hidden' name='productName[]' value='Cement - 50kg')
                input(type='hidden' name='unitCost[]' value='30000')
              .col-lg-3
                label.form-label.fw-semibold.text-secondary Selling Price (UGX)
                input.form-control.form-control-lg(type='number' name='sellingPrice[]' value='35000' required='')
              .col-lg-3
                label.form-label.fw-semibold.text-secondary Profit Margin
                .d-flex.align-items-center.gap-3
                  .progress.rounded-pill.flex-grow-1
                    .progress-bar.purple-bg.rounded-pill(style='width: 16.7%;')
                  strong.purple-text 16.7%
              .col-lg-3.text-lg-end
                p.text-secondary.mb-1 Profit per Unit
                h4.fw-bold.mb-0 5,000 UGX
          // Item 2
          .border.rounded-4.p-4.mb-3
            .row.g-3.align-items-center
              .col-lg-3
                h5.fw-bold.mb-1 Iron Bars - 12mm
                p.text-secondary.mb-0 Cost: 48,000 UGX
