extends layoutadmin 
block content
    // SUPPLIER CREDIT CONTENT
    // Top Summary Cards
    .row.g-4.mb-4
      .col-md-4
        .card.border-0.shadow-sm.h-100
          .card-body.p-4
            p.text-secondary.mb-2 Total Outstanding
            h2.fw-bold.mb-0 41,250,000 UGX
      .col-md-4
        .card.border-0.shadow-sm.h-100
          .card-body.p-4
            p.text-secondary.mb-2 Overdue Credits
            h2.fw-bold.purple-text.mb-0 2
      .col-md-4
        .card.border-0.shadow-sm.h-100
          .card-body.p-4
            p.text-secondary.mb-2 Total Credits
            h2.fw-bold.mb-0 6
    // Record New Credit Button
    .d-flex.justify-content-end.mb-4
      button.btn.purple-bg.text-white.btn-lg.fw-bold.px-5.py-3.purpleBtns(data-bs-toggle='modal' data-bs-target='#recordCreditModal')
        i.bi.bi-plus-lg.me-3
        | Record New Credit
    // Supplier Credit Transactions Table
    .card.border-0.shadow-sm
      .card-body.p-0
        .p-4.border-bottom
          h4.fw-bold.mb-0 Supplier Credit Transactions
        .table-responsive
          table.table.align-middle.mb-0
            thead.table-light
              tr
                th.px-4.py-3.text-uppercase Supplier
                th.px-4.py-3.text-uppercase Goods
                th.px-4.py-3.text-uppercase Amount
                th.px-4.py-3.text-uppercase Due Date
                th.px-4.py-3.text-uppercase Status
                th.px-4.py-3.text-uppercase Action
            tbody
              tr
                td.px-4.py-4.fw-semibold BuildCo Ltd
                td.px-4.py-4.text-secondary Cement - 500 bags
                td.px-4.py-4.fw-semibold 15,000,000 UGX
                td.px-4.py-4.text-secondary 2026-05-20
                td.px-4.py-4
                  span.badge.bg-warning-subtle.text-warning.px-3.py-2.rounded-pill Pending
                td.px-4.py-4
                  button.btn.purple-bg.text-white.fw-bold.px-4.purpleBtns Mark Paid
              tr
                td.px-4.py-4.fw-semibold Steel Works
                td.px-4.py-4.text-secondary Iron Bars - various
                td.px-4.py-4.fw-semibold 8,500,000 UGX
                td.px-4.py-4.text-secondary 2026-05-15
                td.px-4.py-4
                  span.badge.bg-warning-subtle.text-warning.px-3.py-2.rounded-pill Pending
                td.px-4.py-4
                  button.btn.purple-bg.text-white.fw-bold.px-4.purpleBtns Mark Paid
              tr
                td.px-4.py-4.fw-semibold MetalCraft
                td.px-4.py-4.text-secondary Iron Sheets - 200pcs
                td.px-4.py-4.fw-semibold 10,200,000 UGX
                td.px-4.py-4.text-secondary 2026-05-10
                td.px-4.py-4
                  span.badge.bg-danger-subtle.purple-text.px-3.py-2.rounded-pill
                    i.bi.bi-exclamation-circle.me-1
                    | Overdue
                td.px-4.py-4
                  button.btn.purple-bg.text-white.fw-bold.px-4.purpleBtns Mark Paid
              tr
                td.px-4.py-4.fw-semibold Paints R Us
                td.px-4.py-4.text-secondary Paint - 50 buckets
                td.px-4.py-4.fw-semibold 4,750,000 UGX
                td.px-4.py-4.text-secondary 2026-05-25
                td.px-4.py-4
                  span.badge.bg-warning-subtle.text-warning.px-3.py-2.rounded-pill Pending
                td.px-4.py-4
                  button.btn.purple-bg.text-white.fw-bold.px-4.purpleBtns Mark Paid
              tr
                td.px-4.py-4.fw-semibold Hardware Plus
                td.px-4.py-4.text-secondary Nails &amp; Accessories
                td.px-4.py-4.fw-semibold 2,800,000 UGX
                td.px-4.py-4.text-secondary 2026-04-30
                td.px-4.py-4
                  span.badge.bg-danger-subtle.purple-text.px-3.py-2.rounded-pill
                    i.bi.bi-exclamation-circle.me-1
                    | Overdue
                td.px-4.py-4
                  button.btn.purple-bg.text-white.fw-bold.px-4.purpleBtns Mark Paid
              tr
                td.px-4.py-4.fw-semibold BuildCo Ltd
                td.px-4.py-4.text-secondary Cement - 300 bags
                td.px-4.py-4.fw-semibold 9,000,000 UGX
                td.px-4.py-4.text-secondary 2026-04-25
                td.px-4.py-4
                  span.badge.bg-success-subtle.text-success.px-3.py-2.rounded-pill Paid
                td.px-4.py-4
                  span.text-secondary.fw-semibold Completed
    // RECORD NEW CREDIT MODAL
    #recordCreditModal.modal.fade(tabindex='-1' aria-hidden='true')
      .modal-dialog.modal-dialog-centered
        .modal-content.border-0.rounded-4
          .modal-body.p-4.p-md-5
            h3.fw-bold.mb-4 Record New Supplier Credit
            form(action='record-credit.html' method='POST')
              .mb-3
                label.form-label.fw-semibold Supplier Name
                input.form-control(type='text' name='supplierName' placeholder='Enter supplier name' required='')
              .mb-3
                label.form-label.fw-semibold Goods Supplied
                input.form-control(type='text' name='goodsSupplied' placeholder='e.g. Cement - 500 bags' required='')
              .mb-3
                label.form-label.fw-semibold Credit Amount (UGX)
                input.form-control(type='number' name='creditAmount' placeholder='Enter amount' required='')
              .mb-3
                label.form-label.fw-semibold Due Date
                input.form-control(type='date' name='dueDate' required='')
              .mb-4
                label.form-label.fw-semibold Status
                select.form-select(name='creditStatus' required='')
                  option(value='Pending') Pending
                  option(value='Paid') Paid
                  option(value='Overdue') Overdue
              .row.g-3
                .col-6
                  button.btn.btn-outline-secondary.w-100.py-3.fw-bold(type='button' data-bs-dismiss='modal')
                    | Cancel
                .col-6
                  button.btn.purple-bg.text-white.w-100.py-3.fw-bold(type='submit')
                    | Save Credit
script(src='https://cdn.jsdelivr.net/npm/chart.js')
