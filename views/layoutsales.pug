doctype html
head
  meta(charset='UTF-8')
  meta(name='viewport' content='width=device-width, initial-scale=1.0')
  link(href='https://cdn.jsdelivr.net/npm/bootstrap@5.3.8/dist/css/bootstrap.min.css' rel='stylesheet')
  link(href='https://cdn.jsdelivr.net/npm/bootstrap-icons@1.13.1/font/bootstrap-icons.css' rel='stylesheet')
  link(rel='stylesheet' href='/css/style.css')
  style.
// SIDEBAR
body

  aside.sidebar
    .sidebar-header
      .row
        img.col-3(src='/images/logo.png' alt='NyondoStock Logo' width='60px' height='40px')
        h4.fw-bold.mb-1.col-9 NyondoStock
      p.mb-0.text-secondary.topuser Sales Attendant
    .sidebar-menu
      a.sidebar-link.active(href='/salesdashboard')
        i.bi.bi-grid
        |  Dashboard
      a.sidebar-link.active(href='/recordsale')
        i.bi.bi-cart
        |  Record Sale
      a.sidebar-link(href='/stockcheck')
        i.bi.bi-box-seam
        |  Stock Check
      a.sidebar-link(href='/receipts')
        i.bi.bi-receipt
        |  Receipts
    .sidebar-footer
      a.sidebar-link.mb-0(href='/login')
        i.bi.bi-box-arrow-right
        |  Logout
  // MAIN
  main.main
    // TOPBAR
    .topbar
      h3.fw-bold.mb-0 Dashboard
      .d-flex.align-items-center.gap-3
        button.btn.border.rounded-4.position-relative.p-3
          i.bi.bi-bell.fs-4
          span.position-absolute.top-0.end-0.translate-middle.p-1.bg-danger.border.border-light.rounded-circle
        button.btn.bg-light.rounded-4.px-4.py-3.fw-bold
          i.bi.bi-person.me-2
          |  Sales User
    // SCROLLABLE CONTENT
    .content
      block content