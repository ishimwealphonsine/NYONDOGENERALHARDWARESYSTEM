extends layoutsales 
block content
    // RECORD SALE CONTENT
    .card.border-0.shadow-sm
      .card-body.p-4
        .d-flex.align-items-center.gap-3.mb-4
          .purple-bg.text-white.rounded-4.d-flex.align-items-center.justify-content-center.icon
            i.bi.bi-cart-plus.fs-3
          div
            h3.fw-bold.mb-1 Record Sale
            p.text-secondary.mb-0 Complete a customer purchase and issue receipt
        form(action='record-sale.html' method='POST')
          .mb-4
            label.form-label.fw-semibold Customer Name
            input.form-control.form-control-lg(type='text' name='customerName' placeholder='Enter customer name' required='')
          .mb-4
            label.form-label.fw-semibold Customer Phone
            input.form-control.form-control-lg(type='text' name='customerPhone' placeholder='Enter customer phone' required='')
          .mb-4
            label.form-label.fw-semibold Customer Address
            input.form-control.form-control-lg(type='text' name='customerAddress' placeholder='Enter customer address' required='')
          .mb-4
            label.form-label.fw-semibold Customer Distance (KM)
            input.form-control.form-control-lg(type='text' name='customerDistance' placeholder='Enter customer distance' required='')
          .mb-4
            label.form-label.fw-semibold Product
            select.form-select.form-select-lg(name='product' required='')
              option(value='') Select product...
              option(value='Cement - 50kg') Cement - 50kg
              option(value='Iron Bars - 12mm') Iron Bars - 12mm
              option(value='Iron Bars - 16mm') Iron Bars - 16mm
              option(value='Iron Sheets') Iron Sheets
              option(value='Nails - 3 inch') Nails - 3 inch
              option(value='Wire Mesh') Wire Mesh
          .mb-4
            label.form-label.fw-semibold Quantity
            input.form-control.form-control-lg(type='number' name='quantity' placeholder='Enter quantity' required='')
          .mb-4
            label.form-label.fw-semibold Selling Price (UGX)
            input.form-control.form-control-lg(type='number' name='sellingPrice' placeholder='Enter selling price' required='')
          .mb-4
            label.form-label.fw-semibold Payment Method
            select.form-select.form-select-lg(name='paymentMethod' required='')
              option(value='') Select payment method...
              option(value='Cash') Cash
              option(value='Mobile Money') Mobile Money
          .bg-light.rounded-4.p-4.mb-4
            h4.fw-bold.mb-3 Transport Rule
            p.text-secondary.mb-2
              | &bull; Free delivery applies when purchase is at least 500,000 UGX and within
              | 10km.
            p.text-secondary.mb-0 &bull; Otherwise, transport charge is 30,000 UGX.
          button.btn.purple-bg.purpleBtns.text-white.btn-lg.fw-bold.w-100.py-3(type='submit')
            | Complete Sale
