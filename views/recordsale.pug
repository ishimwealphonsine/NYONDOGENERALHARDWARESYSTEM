doctype html
head
  meta(charset='UTF-8')
  meta(name='viewport' content='width=device-width, initial-scale=1.0')
  title Sales Dashboard
  link(href='https://cdn.jsdelivr.net/npm/bootstrap@5.3.8/dist/css/bootstrap.min.css' rel='stylesheet')
  link(href='https://cdn.jsdelivr.net/npm/bootstrap-icons@1.13.1/font/bootstrap-icons.css' rel='stylesheet')
  link(rel='stylesheet' href='style.css')
  style.
// SIDEBAR
aside.sidebar
  .sidebar-header
    .row
      img.col-3(src='/public/images/logo.png' alt='NyondoStock Logo' width='60px' height='40px')
      h4.fw-bold.mb-1.col-9 NyondoStock
    p.mb-0.text-secondary.topuser Sales Attendant
  .sidebar-menu
    a.sidebar-link.active(href='salesdashboard.html')
      i.bi.bi-grid
      |  Dashboard
    a.sidebar-link.active(href='recordsale.html')
      i.bi.bi-people
      |  Record Sale
    a.sidebar-link(href='stockcheck.html')
      i.bi.bi-credit-card
      |  Stock Check
    a.sidebar-link(href='receipts.html')
      i.bi.bi-truck
      |  Receipts
  .sidebar-footer
    a.sidebar-link.mb-0(href='login.html')
      i.bi.bi-box-arrow-right
      |  Logout
// MAIN
main.main
  // TOPBAR
  .topbar
    h3.fw-bold.mb-0 Record Sale
    .d-flex.align-items-center.gap-3
      button.btn.border.rounded-4.position-relative.p-3
        i.bi.bi-bell.fs-4
        span.position-absolute.top-0.end-0.translate-middle.p-1.bg-danger.border.border-light.rounded-circle
      button.btn.bg-light.rounded-4.px-4.py-3.fw-bold
        i.bi.bi-person.me-2
        |  Sales User
  // SCROLLABLE CONTENT
  .content
    // RECORD SALE CONTENT
    .card.border-0.shadow-sm
      .card-body.p-4
        .d-flex.align-items-center.gap-3.mb-4
          .purple-bg.text-white.rounded-4.d-flex.align-items-center.justify-content-center.icon
            i.bi.bi-cart-plus.fs-3
          div
            h3.fw-bold.mb-1 Record Sale
            p.text-secondary.mb-0 Complete a customer purchase and issue receipt
        form(action='record-sale.html' method='POST')
          .mb-4
            label.form-label.fw-semibold Customer Name
            input.form-control.form-control-lg(type='text' name='customerName' placeholder='Enter customer name' required='')
          .mb-4
            label.form-label.fw-semibold Product
            select.form-select.form-select-lg(name='product' required='')
              option(value='') Select product...
              option(value='Cement - 50kg') Cement - 50kg
              option(value='Iron Bars - 12mm') Iron Bars - 12mm
              option(value='Iron Bars - 16mm') Iron Bars - 16mm
              option(value='Iron Sheets') Iron Sheets
              option(value='Nails - 3 inch') Nails - 3 inch
              option(value='Wire Mesh') Wire Mesh
          .mb-4
            label.form-label.fw-semibold Quantity
            input.form-control.form-control-lg(type='number' name='quantity' placeholder='Enter quantity' required='')
          .mb-4
            label.form-label.fw-semibold Unit Price (UGX)
            input.form-control.form-control-lg(type='number' name='unitPrice' placeholder='Enter unit price' required='')
          .mb-4
            label.form-label.fw-semibold Payment Method
            select.form-select.form-select-lg(name='paymentMethod' required='')
              option(value='') Select payment method...
              option(value='Cash') Cash
              option(value='Mobile Money') Mobile Money
              option(value='Bank Transfer') Bank Transfer
          .mb-4
            label.form-label.fw-semibold Transport Distance (KM)
            input.form-control.form-control-lg(type='number' name='transportDistance' placeholder='Enter distance in KM')
          .bg-light.rounded-4.p-4.mb-4
            h4.fw-bold.mb-3 Transport Rule
            p.text-secondary.mb-2
              | &bull; Free delivery applies when purchase is at least 500,000 UGX and within
              | 10km.
            p.text-secondary.mb-0 &bull; Otherwise, transport charge is 30,000 UGX.
          button.btn.purple-bg.purpleBtns.text-white.btn-lg.fw-bold.w-100.py-3(type='submit')
            | Complete Sale
