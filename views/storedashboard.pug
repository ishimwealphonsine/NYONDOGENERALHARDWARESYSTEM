extends layoutstore 
block content
    // STORE MANAGER DASHBOARD CONTENT
    .row.g-4.mb-4
      .col-md-6.col-xl-3
        .card.border-0.shadow-sm.h-100
          .card-body.p-4
            .purple-bg.text-white.rounded-4.d-flex.align-items-center.justify-content-center.dashboard-icon.mb-4
              i.bi.bi-box-seam.fs-3
            p.text-secondary.mb-2 Total Products
            h2.fw-bold.mb-0 127
      .col-md-6.col-xl-3
        .card.border-0.shadow-sm.h-100
          .card-body.p-4
            .purple-bg.text-white.rounded-4.d-flex.align-items-center.justify-content-center.dashboard-icon.mb-4
              i.bi.bi-exclamation-circle.fs-3
            p.text-secondary.mb-2 Low Stock Items
            h2.fw-bold.mb-0 8
      .col-md-6.col-xl-3
        .card.border-0.shadow-sm.h-100
          .card-body.p-4
            .purple-bg.text-white.rounded-4.d-flex.align-items-center.justify-content-center.dashboard-icon.mb-4
              i.bi.bi-graph-up-arrow.fs-3
            p.text-secondary.mb-2 Stock Value
            h2.fw-bold.mb-0 125M UGX
      .col-md-6.col-xl-3
        .card.border-0.shadow-sm.h-100
          .card-body.p-4
            .purple-bg.text-white.rounded-4.d-flex.align-items-center.justify-content-center.dashboard-icon.mb-4
              i.bi.bi-boxes.fs-3
            p.text-secondary.mb-2 Categories
            h2.fw-bold.mb-0 12
    .row.g-4.mb-4
      .col-lg-6
        .card.border-0.shadow-sm.h-100
          .card-body.p-4
            h4.fw-bold.mb-4 Current Stock Levels
            canvas#stockLevelsChart(height='240')
      .col-lg-6
        .card.border-0.shadow-sm.h-100
          .card-body.p-4
            h4.fw-bold.mb-4 Stock Movement Trends
            canvas#stockMovementChart(height='240')
    .card.border-0.shadow-sm.mb-4
      .card-body.p-4
        .d-flex.align-items-center.gap-3.mb-4
          i.bi.bi-exclamation-circle.fs-2.purple-text
          h4.fw-bold.mb-0 Low Stock Alerts
        .row.g-3
          .col-md-6.col-xl-3
            .alert-box
              h5.fw-bold.mb-2 Iron Sheets
              p.text-secondary.mb-0 Restock required
          .col-md-6.col-xl-3
            .alert-box
              h5.fw-bold.mb-2 Paint - 20L
              p.text-secondary.mb-0 Restock required
          .col-md-6.col-xl-3
            .alert-box
              h5.fw-bold.mb-2 Wire Mesh
              p.text-secondary.mb-0 Restock required
          .col-md-6.col-xl-3
            .alert-box
              h5.fw-bold.mb-2 Roofing Nails
              p.text-secondary.mb-0 Restock required
    script(src='https://cdn.jsdelivr.net/npm/chart.js')
    script.
      const stockLevelsCtx = document.getElementById("stockLevelsChart").getContext("2d");
      new Chart(stockLevelsCtx, {
      type: "bar",
      data: {
      labels: ["Cement", "Iron Bars 16mm", "Iron Sheets", "Nails", "Paint"],
      datasets: [{
      label: "stock",
      data: [2400, 850, 450, 180, 45],
      backgroundColor: "#e728f1",
      hoverBackgroundColor: "#e728f1",
      borderColor: "#e728f1",
      borderWidth: 0
      }]
      },
      options: {
      responsive: true,
      animation: {
      duration: 1500,
      easing: "easeOutQuart"
      },
      interaction: {
      mode: "point",
      intersect: true
      },
      plugins: {
      legend: {
      display: false
      },
      tooltip: {
      enabled: true,
      displayColors: false,
      backgroundColor: "#ffffff",
      titleColor: "#000000",
      bodyColor: "#e728f1",
      borderColor: "#dddddd",
      borderWidth: 1,
      padding: 12,
      callbacks: {
      label: function (context) {
      return "stock : " + context.raw;
      }
      }
      }
      },
      scales: {
      y: {
      beginAtZero: true,
      suggestedMax: 2400,
      ticks: {
      stepSize: 600
      },
      grid: {
      color: "#d7d7d7"
      }
      },
      x: {
      grid: {
      color: "#d7d7d7"
      }
      }
      }
      }
      });
      const stockMovementCtx = document.getElementById("stockMovementChart").getContext("2d");
      new Chart(stockMovementCtx, {
      type: "line",
      data: {
      labels: ["Jan", "Feb", "Mar", "Apr", "May"],
      datasets: [
      {
      label: "incoming",
      data: [4000, 3000, 2000, 2800, 1900],
      borderColor: "#e728f1",
      backgroundColor: "#e728f1",
      borderWidth: 3,
      tension: 0.45,
      pointRadius: 4,
      pointHoverRadius: 6,
      pointBackgroundColor: "#ffffff",
      pointBorderColor: "#e728f1",
      pointBorderWidth: 2
      },
      {
      label: "outgoing",
      data: [4000, 3000, 2000, 2800, 1900],
      borderColor: "#160016",
      backgroundColor: "#160016",
      borderWidth: 3,
      tension: 0.45,
      pointRadius: 4,
      pointHoverRadius: 6,
      pointBackgroundColor: "#ffffff",
      pointBorderColor: "#160016",
      pointBorderWidth: 2
      }
      ]
      },
      options: {
      responsive: true,
      animation: {
      duration: 1500,
      easing: "easeOutQuart"
      },
      interaction: {
      mode: "point",
      intersect: true
      },
      plugins: {
      legend: {
      position: "bottom"
      },
      tooltip: {
      enabled: true,
      displayColors: false,
      backgroundColor: "#ffffff",
      titleColor: "#000000",
      bodyColor: "#000000",
      borderColor: "#dddddd",
      borderWidth: 1,
      padding: 12
      }
      },
      scales: {
      y: {
      beginAtZero: true,
      suggestedMax: 6000,
      ticks: {
      stepSize: 1500
      },
      grid: {
      color: "#d7d7d7"
      }
      },
      x: {
      grid: {
      color: "#d7d7d7"
      }
      }
      }
      }
      });
