extends layoutadmin 
block content
    // USER MANAGEMENT CONTENT
    // Search + Create User
    .card.border-0.shadow-sm.mb-4
      .card-body.p-4
        .row.g-3.align-items-center
          .col-lg-9
            .input-group.input-group-lg
              span.input-group-text.bg-white.border-end-0
                i.bi.bi-search.text-secondary
              input.form-control.border-start-0(type='search' placeholder='Search users...' name='searchUser')
          .col-lg-3.d-grid
            button.btn.purple-bg.text-white.btn-lg.fw-bold.purpleBtns(data-bs-toggle='modal' data-bs-target='#createUserModal')
              i.bi.bi-person-plus.me-2
              | Create User
    // All Users Table
    .card.border-0.shadow-sm
      .card-body.p-0
        .p-4.border-bottom
          h4.fw-bold.mb-0 All Users (5)
        .table-responsive
          table.table.align-middle.mb-0
            thead.table-light
              tr
                th.px-4.py-3.text-uppercase Name
                th.px-4.py-3.text-uppercase Username
                th.px-4.py-3.text-uppercase Role
                th.px-4.py-3.text-uppercase Status
                th.px-4.py-3.text-uppercase Created
                th.px-4.py-3.text-uppercase Actions
            tbody
              tr
                td.px-4.py-4.fw-semibold John Kamau
                td.px-4.py-4.text-secondary jkamau
                td.px-4.py-4.text-secondary Sales Attendant
                td.px-4.py-4
                  span.badge.bg-success-subtle.text-success.px-3.py-2.rounded-pill active
                td.px-4.py-4.text-secondary 2026-01-15
                td.px-4.py-4
                  button.btn.btn-link.purple-text.p-0.me-4.purpleIcons
                    i.bi.bi-pencil-square.fs-5
                  button.btn.btn-link.text-danger.p-0
                    i.bi.bi-trash.fs-5
              tr
                td.px-4.py-4.fw-semibold Mary Achieng
                td.px-4.py-4.text-secondary machieng
                td.px-4.py-4.text-secondary Sales Attendant
                td.px-4.py-4
                  span.badge.bg-success-subtle.text-success.px-3.py-2.rounded-pill active
                td.px-4.py-4.text-secondary 2026-02-10
                td.px-4.py-4
                  button.btn.btn-link.purple-text.p-0.me-4.purpleIcons
                    i.bi.bi-pencil-square.fs-5
                  button.btn.btn-link.text-danger.p-0
                    i.bi.bi-trash.fs-5
              tr
                td.px-4.py-4.fw-semibold David Ouma
                td.px-4.py-4.text-secondary douma
                td.px-4.py-4.text-secondary Store Manager
                td.px-4.py-4
                  span.badge.bg-success-subtle.text-success.px-3.py-2.rounded-pill active
                td.px-4.py-4.text-secondary 2026-01-20
                td.px-4.py-4
                  button.btn.btn-link.purple-text.p-0.me-4.purpleIcons
                    i.bi.bi-pencil-square.fs-5
                  button.btn.btn-link.text-danger.p-0
                    i.bi.bi-trash.fs-5
              tr
                td.px-4.py-4.fw-semibold Sarah Wanjiku
                td.px-4.py-4.text-secondary swanjiku
                td.px-4.py-4.text-secondary Accounts/Admin
                td.px-4.py-4
                  span.badge.bg-success-subtle.text-success.px-3.py-2.rounded-pill active
                td.px-4.py-4.text-secondary 2026-03-05
                td.px-4.py-4
                  button.btn.btn-link.purple-text.p-0.me-4.purpleIcons
                    i.bi.bi-pencil-square.fs-5
                  button.btn.btn-link.text-danger.p-0
                    i.bi.bi-trash.fs-5
              tr
                td.px-4.py-4.fw-semibold Peter Okello
                td.px-4.py-4.text-secondary pokello
                td.px-4.py-4.text-secondary Sales Attendant
                td.px-4.py-4
                  span.badge.bg-secondary-subtle.text-dark.px-3.py-2.rounded-pill inactive
                td.px-4.py-4.text-secondary 2025-12-01
                td.px-4.py-4
                  button.btn.btn-link.purple-text.p-0.me-4.purpleIcons
                    i.bi.bi-pencil-square.fs-5
                  button.btn.btn-link.text-danger.p-0
                    i.bi.bi-trash.fs-5
// pop up of creating a new user
#createUserModal.modal.fade(tabindex='-1' aria-hidden='true')
  .modal-dialog.modal-dialog-centered
    .modal-content.border-0.rounded-4
      .modal-body.p-4.p-md-5
        h3.fw-bold.mb-4 Create New User
        form(action='create-user.html' method='POST')
          .mb-3
            label.form-label.fw-semibold Full Name
            input.form-control(type='text' name='fullName' placeholder='Enter full name' required='')
          .mb-3
            label.form-label.fw-semibold Username
            input.form-control(type='text' name='username' placeholder='Enter username' required='')
          .mb-3
            label.form-label.fw-semibold Role
            select.form-select(name='role' required='')
              option(value='Sales Attendant') Sales Attendant
              option(value='Store Manager') Store Manager
              option(value='Accounts/Admin') Accounts/Admin
          .mb-4
            label.form-label.fw-semibold Password
            input.form-control(type='password' name='password' placeholder='Enter password' required='')
          .row.g-3
            .col-6
              button.btn.btn-outline-secondary.w-100.py-3.fw-bold(type='button' data-bs-dismiss='modal')
                | Cancel
            .col-6
              button.btn.purple-bg.text-white.w-100.py-3.fw-bold.purpleBtns(type='submit')
                | Create User
script(src='https://cdn.jsdelivr.net/npm/chart.js')
script(src='https://cdn.jsdelivr.net/npm/bootstrap@5.3.8/dist/js/bootstrap.bundle.min.js')
