doctype html
head
  meta(charset='UTF-8')
  meta(name='viewport' content='width=device-width, initial-scale=1.0')
  title Stock Management
  link(rel='stylesheet' href='../static/css/style.css')
  link(href='https://cdn.jsdelivr.net/npm/bootstrap@5.3.8/dist/css/bootstrap.min.css' rel='stylesheet' integrity='sha384-sRIl4kxILFvY47J16cr9ZwB07vP4J8+LH7qKQnuqkuIAvNWLzeN8tE5YBujZqJLB' crossorigin='anonymous')
  script(src='https://kit.fontawesome.com/e53d7a7b30.js' crossorigin='anonymous')
.container-fluid
  .row.overallbox.input-group.input-group-lg
    .col-3.bg-light.sidebar.d-flex.flex-column
      // <div class="d-flex">
      // Sidebar
      // Logo
      h5.text-dark.mb-4.mt-3
        span.text-light.px-2.py-1.rounded
          img#logo(src='../static/images/NyondoStockLogo.png' alt='NyondoStock Logo')
        strong NyondoStock
      // Menu
      ul.nav.flex-column
        li.nav-item.mb-2
          a.nav-link.text-dark.rounded.link-light.link-offset-2.link-underline-opacity-25.link-underline-opacity-100-hover(href='#')
            i.fa-solid.fa-table-cells
            | Dashboard
        // Active
        li.nav-item.mb-2
          a.nav-link.text-dark.rounded.link-light.link-offset-2.link-underline-opacity-25.link-underline-opacity-100-hover(href='#')
            i.fa-solid.fa-arrow-trend-up
            |               Stock Management
        li.nav-item.mb-2
          a.nav-link.text-dark.rounded.link-light.link-offset-2.link-underline-opacity-25.link-underline-opacity-100-hover(href='#')
            i.fa-solid.fa-cart-shopping
            | Sales
        li.nav-item.mb-2
          a.nav-link.text-dark.rounded.link-light.link-offset-2.link-underline-opacity-25.link-underline-opacity-100-hover(href='#')
            i.fa-solid.fa-credit-card
            | Supplier Credit
        li.nav-item.mb-2
          a.nav-link.text-dark.rounded.link-light.link-offset-2.link-underline-opacity-25.link-underline-opacity-100-hover(href='#')
            i.fa-solid.fa-piggy-bank
            | Deposit Scheme
        li.nav-item.mb-2
          a.nav-link.text-dark.rounded.link-light.link-offset-2.link-underline-opacity-25.link-underline-opacity-100-hover(href='#')
            i.fa-solid.fa-chart-bar
            | Reports
        li.nav-item.mb-4
          a.nav-link.text-dark.rounded.link-light.link-offset-2.link-underline-opacity-25.link-underline-opacity-100-hover(href='#')
            i.fa-solid.fa-users
            | Users
      // Bottom section
      .mt-auto
        hr
        ul.nav.flex-column
          li.nav-item
            a.nav-link.text-dark.rounded.link-light.link-offset-2.link-underline-opacity-25.link-underline-opacity-100-hover(href='#')
              i.fa-solid.fa-gear
              | Settings
          li.nav-item
            a.nav-link.text-dark.rounded.link-light.link-offset-2.link-underline-opacity-25.link-underline-opacity-100-hover(href='#')
              i.fa-regular.fa-circle-question
              | Help Center
          li.nav-item
            a.nav-link.text-dark.rounded.link-light.link-offset-2.link-underline-opacity-25.link-underline-opacity-100-hover(href='#')
              i.fa-solid.fa-arrow-right-from-bracket
              | Logout
    // ------------------------------------main content--------------------------------------------
    .col-9.bg-light.main-content
      // Top Bar
      .bg-light.p-3.border-bottom.d-flex.justify-content-between.align-items-center
        // Search
        input.form-control.w-50(type='text' placeholder='Search products...')
        // Right side
        .d-flex.align-items-center.gap-3
          // Notification
          .position-relative
            span.fs-5 &#x1F514;
            span.position-absolute.top-0.start-100.translate-middle.badge.rounded-pill.bg-success.text-light
              | 5
          // User
          .d-flex.align-items-center.gap-2
            img.rounded-circle(src='/css/images/me-2.png' width='35')
            div
              .text-dark.fw-bold Ishimwe Alphonsine
              small.text-muted Stock Manager
      // Page Header
      .p-4.bg-light
        .d-flex.justify-content-between.align-items-center.mb-4
          // Title
          div
            h3.text-dark.fw-bold Stock Management
            p.text-muted.mb-0
              | Manage and monitor all hardware inventory levels.
          // Buttons
          .d-flex.gap-2
            button.btn.btn-outline-dark
              i.fa-solid.fa-download
              |                 Export
            a.addproductbtn(href='addnewproduct.html')
              button.btn.bg-success.text-light
                i.fa-solid.fa-plus
                |                   Add Product
        // Cards
        .d-flex.g-3.justify-content-between.gap-3
          // Card 1
          .col-md
            .card.p-3.border-0
              small.text-muted Total Products
              h4.text-dark 120
              small.text-muted +4 added this week
          // Card 2
          .col-md
            .card.p-3.border-0
              small.text-muted Total Stock Units
              h4.text-dark 8,540
              small.text-muted Across 8 categories
          // Card 3
          .col-md
            .card.p-3.border-0
              small.text-muted Stock Value
              h4.text-dark UGX 45.2M
              small.text-muted Estimated cost basis
          // Card 4
          .col-md
            .card.p-3.border-0
              small.text-muted Low Stock Items
              h4.text-dark 12
              small.text-muted Requires attention
          // Card 5
          .col-md
            .card.p-3.border-0
              small.text-muted Out of Stock
              h4.text-dark 5
              small.text-muted Immediate restock needed
        // Table
        .bg-light.p-4.inventory-table.mt-5
          // Header
          .d-flex.justify-content-between.align-items-center.mb-3
            div
              h5.text-dark.fw-bold.mb-0 Inventory List
              small.text-muted Comprehensive list of all products in store
            button.btn.btn-outline-dark.btn-sm &#x1F4C4; View History
          // Filters
          .d-flex.gap-2.mb-3
            input.form-control(type='text' placeholder='Filter by product name...')
            button.btn.btn-outline-dark &#x26B2;
            input.form-control(type='text' placeholder='Category')
            input.form-control(type='text' placeholder='Status')
          // Table
          .card.border-0.shadow-sm
            .table-responsive
              table.table.align-middle.mb-0
                thead.bg-light
                  tr.text-dark
                    th Product ID
                    th Product Name
                    th Category
                    th Qty
                    th Cost (UGX)
                    th Price (UGX)
                    th Status
                    th Actions
                tbody
                  tr
                    td PRD-001
                    td Cement 50kg (Simba)
                    td
                      span.badge.bg-light.text-dark Masonry
                    td 450
                    td 32,000
                    td 38,000
                    td
                      span.text-success In Stock
                    td &vellip;
                  tr
                    td PRD-002
                    td Steel Rods 12mm
                    td
                      span.badge.bg-light.text-dark Metal
                    td 12
                    td 45,000
                    td 52,000
                    td
                      span.text-warning Low Stock
                    td &vellip;
                  tr
                    td PRD-003
                    td PVC Pipe 4&quot;
                    td
                      span.badge.bg-light.text-dark Plumbing
                    td 85
                    td 15,000
                    td 19,500
                    td
                      span.text-success In Stock
                    td &vellip;
                  tr.bg-light
                    td PRD-004
                    td Roofing Nails 2&quot;
                    td
                      span.badge.bg-light.text-dark Fasteners
                    td 0
                    td 5,000
                    td 7,500
                    td
                      span.badge.bg-danger.text-light Out of Stock
                    td &vellip;
                  tr
                    td PRD-005
                    td Copper Wire 2.5mm
                    td
                      span.badge.bg-light.text-dark Electrical
                    td 120
                    td 120,000
                    td 145,000
                    td
                      span.text-success In Stock
                    td &vellip;
                  tr
                    td PRD-006
                    td Paint - White Silk 20L
                    td
                      span.badge.bg-light.text-dark Finishes
                    td 8
                    td 180,000
                    td 210,000
                    td
                      span.text-warning Low Stock
                    td &vellip;
          // Footer
          .d-flex.justify-content-between.align-items-center.mt-3
            small.text-muted Showing 1-6 of 120 products
            .d-flex.gap-1
              button.btn.btn-outline-dark.btn-sm Previous
              button.btn.bg-success.text-light.btn-sm 1
              button.btn.btn-outline-dark.btn-sm 2
              button.btn.btn-outline-dark.btn-sm 3
              button.btn.btn-outline-dark.btn-sm ...
              button.btn.btn-outline-dark.btn-sm 20
              button.btn.btn-outline-dark.btn-sm Next
        // Charts Section
        .bg-light.p-4.mt-5.chart-section
          .row.g-3
            // Bar Chart
            .col-md-8
              .card.border-0.shadow-sm.p-3
                h6.text-dark.fw-bold Stock Levels by Category
                small.text-muted Aggregated inventory units per hardware department
                canvas#barChart(height='120')
            // Doughnut Chart
            .col-md-4
              .card.border-0.shadow-sm.p-3
                h6.text-dark.fw-bold Inventory Value
                small.text-muted Value distribution across categories
                canvas#pieChart(height='180')
                // Legend
                .mt-3.small
                  .d-flex.justify-content-between
                    span &#x25CF; Masonry
                    span 45%
                  .d-flex.justify-content-between
                    span &#x25CF; Metal
                    span 25%
                  .d-flex.justify-content-between
                    span &#x25CF; Plumbing
                    span 15%
        // Chart.js
        script(src='https://cdn.jsdelivr.net/npm/chart.js')
        // <script src="https://cdn.jsdelivr.net/npm/chart.js@4.5.1/dist/chart.umd.min.js"></script>
        script.
          // Bar Chart
          new Chart(document.getElementById('barChart'), {
          type: 'bar',
          data: {
          labels: ['Masonry', 'Metal', 'Plumbing', 'Electrical', 'Finishes'],
          datasets: [{
          data: [1200, 850, 450, 650, 300],
          backgroundColor: '#198754' // success green
          }]
          },
          options: {
          plugins: { legend: { display: false } },
          scales: {
          y: { beginAtZero: true }
          }
          }
          });
          // Doughnut Chart
          new Chart(document.getElementById('pieChart'), {
          type: 'doughnut',
          data: {
          labels: ['Masonry', 'Metal', 'Plumbing', 'Electrical', 'Others'],
          datasets: [{
          data: [45, 25, 15, 10, 5],
          backgroundColor: [
          '#198754',
          '#000000',
          '#6c757d',
          '#adb5bd',
          '#dee2e6'
          ]
          }]
          },
          options: {
          plugins: { legend: { display: false } }
          }
          });
      // Footer
      .bg-light.text-center.py-3.mt-5.border-top
        small.text-dark
          | &copy; 2026 NyondoStock Hardware Inventory. All rights reserved.
