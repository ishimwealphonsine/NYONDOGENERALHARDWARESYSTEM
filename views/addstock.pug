doctype html
head
  meta(charset='UTF-8')
  meta(name='viewport' content='width=device-width, initial-scale=1.0')
  title Add New Product
  link(rel='stylesheet' href='/css/style.css')
  link(href='https://cdn.jsdelivr.net/npm/bootstrap@5.3.8/dist/css/bootstrap.min.css' rel='stylesheet' integrity='sha384-sRIl4kxILFvY47J16cr9ZwB07vP4J8+LH7qKQnuqkuIAvNWLzeN8tE5YBujZqJLB' crossorigin='anonymous')
  script(src='https://kit.fontawesome.com/e53d7a7b30.js' crossorigin='anonymous')
// Modal
.modal.fade.show.d-block(tabindex='-1')
  .modal-dialog.modal-lg.addnewproductpage
    .modal-content.bg-light
      form(action='/add-stock' method='post')
        // Header
        .modal-header.border-bottom
          div
            h5.modal-title.text-dark.fw-bold
              span.bg-primary.text-light.px-2.py-1.rounded.me-2 +
              |                 Add New Product
            small.text-muted
              | Register a new item into the hardware inventory system.
          button.btn-close(type='button')
        // Body
        .modal-body
          // Product Name
          .mb-3
            label.form-label.text-dark(for='product_name') Product Name *
            input#product_name.form-control(type='text' name='productName' placeholder='e.g., Heavy Duty Cement Mixer 200L' required='')
          // Row
          .row
            .col-md-6.mb-3
              label.form-label.text-dark(for='category') Category *
              select#category.form-control(name='category' required='')
                option(value='Construction Tools') Construction Tools
            .col-md-6.mb-3
              label.form-label.text-dark(for='supplier') Supplier Name
              select#supplier.form-control(type='text' name='supplier')
                option(value='') Select supplier
          // Row
          .row
            .col-md-6.mb-3
              label.form-label.text-dark(for='initial_stock_quantity')
                | Stock Quantity *
              input#initial_stock_quantity.form-control(type='number' name='stockQuantity' placeholder='0' min='0' required='')
            .col-md-6.mb-3
              label.form-label.text-dark(for='date_received') Date Received *
              input#date_received.form-control(type='date' name='dateReceived' required='')
          hr
          // Pricing
          h6.text-dark.fw-bold
            | PRICING DETAILS
            span.badge.bg-light.text-dark Currency: UGX
          .row.mt-2
            .col-md-6.mb-3
              label.form-label.text-dark(for='costPrice')
                | Cost Price Buying *
              input#cost_price.form-control(type='number' name='costPrice' placeholder='UGX 0.00' min='0' required='')
            .col-md-6.mb-3
              label.form-label.text-dark(for='sellingPrice')
                | Selling Price Retail *
              input#selling_price.form-control(type='number' name='sellingPrice' placeholder='UGX 0.00' min='0' required='')
        
        .modal-footer.d-flex.justify-content-between
          small.text-muted
            | Fields marked with * are required
          div
            button.btn.btn-outline-dark(type='cancel')
              | Cancel
            button.btn-purple(type='submit')
              | Add Product
